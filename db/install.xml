<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/course_reminder/db" VERSION="20260406" COMMENT="XMLDB file for local_course_reminder"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="local_course_reminder_log" COMMENT="Tracks when the last reminder email was sent per user/course/type">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="mdl_user.id"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="mdl_course.id"/>
        <FIELD NAME="remindertype" TYPE="char" LENGTH="20" NOTNULL="true" SEQUENCE="false" COMMENT="manager or student"/>
        <FIELD NAME="timesent" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Unix timestamp of last reminder sent"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="userid_courseid_type" UNIQUE="true" FIELDS="userid, courseid, remindertype"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
